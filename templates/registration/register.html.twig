{% extends 'base.html.twig' %}

{# --- SUPPRESSION DE LA NAVBAR --- #}
{% block navbar %}{% endblock %}

{# --- SEO & PERFORMANCE --- #}
{% block meta_tags %}
    <meta name="description" content="Rejoignez Performance ID. Créez votre profil d'athlète et commencez à tracker vos performances dès aujourd'hui.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ app.request.uri }}">
{% endblock %}

{% block title %}Créer un profil | Performance ID{% endblock %}

{% block body %}
<style>
    :root { --primary: #dc3545; --dark-bg: #0a0a0a; }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--dark-bg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        position: relative;
        overflow-x: hidden;
    }

    .auth-bg {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(rgba(0,0,0,0.85), rgba(0,0,0,0.95)), 
                    url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=20&w=1200&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
    }

    .auth-card {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 500px;
        margin: 40px 20px;
        padding: 40px;
        background: rgba(17, 17, 17, 0.95);
        border-top: 4px solid var(--primary);
        box-shadow: 0 10px 40px rgba(0,0,0,0.8);
        backdrop-filter: blur(10px);
    }

    .auth-h1 {
        font-family: 'Bebas Neue', Impact, sans-serif;
        font-size: 3rem;
        color: #fff;
        text-align: center;
        margin: 0 0 5px 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .auth-sub {
        display: block;
        text-align: center;
        color: var(--primary);
        font-weight: bold;
        letter-spacing: 2px;
        margin-bottom: 30px;
        font-size: 0.8rem;
    }

    .form-group { margin-bottom: 18px; }

    .form-label {
        display: block;
        color: #bbb;
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .form-input {
        width: 100%;
        padding: 12px;
        background: #222;
        border: 1px solid #333;
        color: #fff;
        font-size: 1rem;
        border-radius: 2px;
        transition: all 0.2s;
    }

    .form-input:focus { 
        outline: none; 
        border-color: var(--primary); 
        background: #282828;
    }

    .form-error-msg ul { list-style: none; padding: 0; margin: 5px 0 0 0; }
    .form-error-msg li { color: #ff8080; font-size: 0.8rem; }

    .btn-submit {
        width: 100%;
        padding: 15px;
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 2px;
        font-weight: bold;
        font-size: 1rem;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: transform 0.2s, background 0.2s;
        margin-top: 10px;
    }

    .btn-submit:hover { 
        background: #bd2130; 
        transform: translateY(-1px);
    }

    .auth-footer { margin-top: 25px; text-align: center; font-size: 0.85rem; color: #666; }
    .auth-footer a { color: #fff; font-weight: bold; text-decoration: none; }
    .auth-footer a:hover { color: var(--primary); }

    .custom-checkbox-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        cursor: pointer;
    }

    .form-check-input {
        accent-color: var(--primary);
        width: 18px;
        height: 18px;
    }

    .checkbox-text { color: #ccc; font-size: 0.85rem; }
</style>

<main class="auth-wrapper">
    <div class="auth-bg" role="presentation"></div>

    <article class="auth-card">
        <header>
            <h1 class="auth-h1">Performance <span style="color:var(--primary)">ID</span></h1>
            <span class="auth-sub">CRÉER VOTRE PROFIL D'ÉLITE</span>
        </header>

        {{ form_start(registrationForm) }}
            <div class="row">
                <div class="col-md-6 form-group">
                    <label class="form-label">Prénom</label>
                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-input', 'placeholder': 'Jean'}}) }}
                    <div class="form-error-msg">{{ form_errors(registrationForm.firstName) }}</div>
                </div>
                <div class="col-md-6 form-group">
                    <label class="form-label">Nom</label>
                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-input', 'placeholder': 'Dupont'}}) }}
                    <div class="form-error-msg">{{ form_errors(registrationForm.lastName) }}</div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Adresse Email</label>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-input', 'placeholder': 'athlete@exemple.com'}}) }}
                <div class="form-error-msg">{{ form_errors(registrationForm.email) }}</div>
            </div>

            <div class="form-group">
                <label class="form-label">Mot de passe</label>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-input', 'placeholder': '••••••••'}}) }}
                <div class="form-error-msg">{{ form_errors(registrationForm.plainPassword) }}</div>
            </div>

            <div class="form-group">
                <label class="custom-checkbox-row">
                    {{ form_widget(registrationForm.agreeTerms, { 'label': false, 'attr': {'class': 'form-check-input'} }) }}
                    <span class="checkbox-text">J'accepte les conditions d'utilisation</span>
                </label>
                <div class="form-error-msg">{{ form_errors(registrationForm.agreeTerms) }}</div>
            </div>

            <button type="submit" class="btn-submit">
                CRÉER MON COMPTE
            </button>
        {{ form_end(registrationForm) }}

        <footer class="auth-footer">
            <p>Déjà inscrit ? <a href="{{ path('app_login') }}">SE CONNECTER</a></p>
            <a href="{{ path('app_home') }}" style="font-size: 0.75rem; color: #444; margin-top: 15px; display: inline-block;">Retour à l'accueil</a>
        </footer>
    </article>
</main>
{% endblock %}