<!DOCTYPE html>
<html lang="fr"> {# 1. Correction Accessibilité : Langue définie #}
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}PERFORMANCE ID{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content="Performance ID - Suivi de performance et musculation">

        {# 2. Optimisation Performance : Preconnect pour les polices Google #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        {# 3. Optimisation Performance : display=swap pour éviter le texte invisible au chargement #}
        <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700&display=swap" rel="stylesheet">

        <style>
            :root { 
                --primary-red: #ff3131; 
                --bg-image: url("{{ asset('images/performance_id.webp') }}");
            }

            body { 
                background: #000;
                color: white; 
                font-family: 'Inter', sans-serif; 
                margin: 0;
            }

            .bg-global {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                /* 4. Optimisation Performance : Dégradé sombre pour améliorer le contraste (Accessibilité) */
                background: linear-gradient(rgba(0,0,0,0.85), rgba(0,0,0,0.85)), var(--bg-image);
                background-repeat: no-repeat;
                background-position: center center;
                background-size: cover;
                z-index: -1;
                /* 5. Optimisation Performance : Éviter les calculs de scroll sur mobile */
                will-change: transform;
            }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div class="bg-global"></div>

        {% block body %}{% endblock %}

        {# 6. Optimisation Performance : Attribut 'defer' pour ne pas bloquer le rendu #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>