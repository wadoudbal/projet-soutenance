{% extends 'base.html.twig' %}

{% block title %}Vérification 2FA{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card border-primary shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Code de vérification</h4>
                </div>
                <div class="card-body">
                    <p>Entrez le code à 6 chiffres généré par votre application mobile.</p>

                    {# On utilise la route configurée pour le traitement #}
                    <form action="{{ path('2fa_login_check') }}" method="post">
                        
                        <div class="mb-3">
                            <input type="text" 
                                   name="_auth_code" 
                                   class="form-control form-control-lg text-center font-monospace" 
                                   placeholder="000000" 
                                   autofocus 
                                   required
                                   autocomplete="one-time-code">
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Confirmer</button>
                        
                        <div class="text-center mt-3">
                            <a href="{{ path('app_logout') }}" class="text-muted small">Annuler et se déconnecter</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}