<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}PERFORMANCE ID{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        
        {# --- 1. PRELOAD L'IMAGE DE FOND (CRITIQUE POUR LA VITESSE) --- #}
        <link rel="preload" as="image" href="{{ asset('images/performance_id.webp') }}">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700&display=swap" rel="stylesheet">

        <style>
            :root { 
                --primary-red: #ff3131; 
                /* On définit l'URL ici */
                --bg-url: url("{{ asset('images/performance_id.webp') }}");
            }

            body { 
                background: #000; /* Couleur de secours instantanée */
                color: white; 
                font-family: 'Inter', sans-serif; 
                margin: 0;
            }

            .bg-global {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                /* Ajout d'une transition douce pour l'apparition */
                transition: opacity 0.5s ease-in-out;
                background: linear-gradient(rgba(0,0,0,0.85), rgba(0,0,0,0.85)), var(--bg-url);
                background-repeat: no-repeat;
                background-position: center center;
                background-size: cover;
                z-index: -1;
                /* Optimisation hardware */
                transform: translateZ(0); 
                backface-visibility: hidden;
            }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div class="bg-global"></div>
        {% block body %}{% endblock %}

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>