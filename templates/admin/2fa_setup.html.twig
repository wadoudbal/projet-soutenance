{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Sécurité du compte{% endblock %}

{% block main %}
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-sm border-0 text-center p-5">
                    
                    {# 1. BADGE DE STATUT DYNAMIQUE #}
                    <div class="mb-4">
                        {% if isEnabled %}
                            <div class="display-4 text-success"><i class="fas fa-check-shield"></i></div>
                            <span class="badge badge-success p-2 mt-2">DOUBLE AUTHENTIFICATION ACTIVÉE</span>
                        {% else %}
                            <div class="display-4 text-warning"><i class="fas fa-shield-alt"></i></div>
                            <span class="badge badge-secondary p-2 mt-2">DOUBLE AUTHENTIFICATION DÉSACTIVÉE</span>
                        {% endif %}
                    </div>

                    <h2 class="font-weight-bold">Configuration 2FA</h2>

                    {% if not isEnabled %}
                        {# --- CAS : LA 2FA N'EST PAS ENCORE ACTIVE --- #}
                        <p class="text-muted mb-4">
                            Scannez ce code avec votre application <strong>Google Authenticator</strong> pour protéger votre accès.
                        </p>
                        
                        <div id="qr-code-container" class="my-4 d-inline-block p-3 bg-white border rounded shadow-sm">
                            {% if qrCodeDataUri %}
                                <img src="{{ qrCodeDataUri }}" 
                                     alt="QR Code 2FA" 
                                     style="width: 250px; height: 250px; display: block; margin: 0 auto;">
                            {% else %}
                                <div class="alert alert-danger">
                                    Erreur de génération du QR Code.
                                </div>
                            {% endif %}
                        </div>

                        <div class="alert alert-light border mt-3 py-3">
                            <small class="text-uppercase text-muted d-block mb-1">Clé de saisie manuelle</small>
                            <code class="h5 text-dark font-weight-bold" style="letter-spacing: 2px;">{{ secret }}</code>
                        </div>

                        <div class="mt-4">
                            <a href="{{ path('admin') }}" class="btn btn-primary btn-lg px-4 shadow">
                                <i class="fas fa-check-circle mr-2"></i> J'ai terminé le scan
                            </a>
                        </div>

                    {% else %}
                        {# --- CAS : LA 2FA EST DÉJÀ ACTIVE --- #}
                        <div class="alert alert-info mt-4">
                            Votre accès est actuellement sécurisé par un code à usage unique.
                        </div>

                        <div class="mt-4">
                            <p class="text-muted">Vous souhaitez changer de téléphone ou désactiver la protection ?</p>
                            <a href="{{ path('admin_2fa_disable') }}" 
                               class="btn btn-outline-danger"
                               onclick="return confirm('Attention : cela réduira la sécurité de votre compte. Continuer ?')">
                                <i class="fas fa-unlock-alt mr-2"></i> Désactiver la protection 2FA
                            </a>
                        </div>
                        
                        <div class="mt-3">
                            <a href="{{ path('admin') }}" class="btn btn-link text-muted">Retour au tableau de bord</a>
                        </div>
                    {% endif %}

                </div>
            </div>
        </div>
    </div>
{% endblock %}