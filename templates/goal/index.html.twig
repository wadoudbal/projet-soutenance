{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="p-4 p-md-5" style="background: rgba(0,0,0,0.7); border: 1px solid rgba(220, 53, 69, 0.4); backdrop-filter: blur(15px);">
                
                <div class="text-center mb-4">
                    <h1 class="text-white m-0" style="font-size: 2.5rem;">FIXER UN <span class="text-danger">OBJECTIF</span></h1>
                    <p class="text-white-50 small text-uppercase">Définit ton prochain palier de force</p>
                </div>

                {{ form_start(form) }}
                    <div class="mb-4">
                        <label class="text-white-50 small text-uppercase fw-bold mb-2">Exercice</label>
                        {{ form_widget(form.exercise, {'attr': {'class': 'form-select bg-dark text-white border-secondary rounded-0 py-3'}}) }}
                    </div>

                    <div class="mb-4">
                        <label class="text-white-50 small text-uppercase fw-bold mb-2">Poids cible (KG)</label>
                        {{ form_widget(form.targetWeight, {'attr': {'class': 'form-control bg-dark text-white border-secondary rounded-0 py-3', 'placeholder': 'Ex: 100'}}) }}
                    </div>

                    <button type="submit" class="btn btn-danger w-100 py-3 fw-bold rounded-0">
                        <i class="bi bi-fire me-2"></i>ACTIVER L'OBJECTIF
                    </button>
                {{ form_end(form) }}

                <div class="text-center mt-4">
                    <a href="{{ path('app_dashboard') }}" class="text-white-50 small text-decoration-none">
                        <i class="bi bi-arrow-left"></i> Annuler
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}