{% extends 'base.html.twig' %}

{% block title %}Sécurité - Performance ID{% endblock %}

{% block body %}
<style>
    :root {
        --primary-red: #ff3131;
    }

    .bebas { font-family: 'Bebas Neue', cursive; letter-spacing: 1px; }
    
    /* On centre tout sur la page sans sidebar */
    .full-page-container { 
        min-height: 100vh; 
        background: #0a0a0a; 
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 2rem;
    }

    .card-dark { 
        background: rgba(20, 20, 20, 0.8); 
        border: 1px solid rgba(255,255,255,0.05); 
        border-top: 4px solid var(--primary-red); 
        color: white; 
        backdrop-filter: blur(20px);
        width: 100%;
        max-width: 450px;
        padding: 2.5rem;
    }

    .form-control-custom {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        padding: 12px;
        border-radius: 0;
        transition: 0.3s;
    }

    .form-control-custom:focus {
        border-color: var(--primary-red) !important;
        box-shadow: none;
        background: rgba(255, 255, 255, 0.08) !important;
    }

    .input-group-text {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--primary-red);
        border-radius: 0;
    }
</style>

<div class="full-page-container">
    <div class="text-center mb-4">
        <h4 class="text-danger mb-0 bebas" style="letter-spacing: 3px;">PROTECTION</h4>
        <h1 class="bebas display-4 m-0 text-white">MOT DE <span class="text-danger">PASSE</span></h1>
    </div>

    <div class="card card-dark shadow-lg">
        {{ form_start(form) }}
            <div class="mb-4">
                <label class="bebas text-white-50 mb-2 small">Mot de passe actuel</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                    {{ form_widget(form.oldPassword, {'attr': {'class': 'form-control form-control-custom', 'placeholder': '••••••••'}}) }}
                </div>
                {{ form_errors(form.oldPassword) }}
            </div>

            <div class="mb-4">
                <label class="bebas text-white-50 mb-2 small">Nouveau mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                    {{ form_widget(form.newPassword.first, {'attr': {'class': 'form-control form-control-custom', 'placeholder': 'Nouveau'}}) }}
                </div>
            </div>

            <div class="mb-5">
                <label class="bebas text-white-50 mb-2 small">Confirmation</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-check-lg"></i></span>
                    {{ form_widget(form.newPassword.second, {'attr': {'class': 'form-control form-control-custom', 'placeholder': 'Répéter'}}) }}
                </div>
                {{ form_errors(form.newPassword.first) }}
            </div>

            <button type="submit" class="btn btn-danger bebas w-100 py-3 fs-5">
                Valider le changement
            </button>

            <div class="text-center mt-4">
                <a href="{{ path('app_profile') }}" class="text-white-50 small text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i> Retour au profil
                </a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}