{% extends 'base.html.twig' %}

{# --- OPTIMISATION SEO --- #}
{% block title %}Performance ID - Dominez votre Surcharge Progressive{% endblock %}

{% block meta_tags %}
    <meta name="description" content="Transformez vos données en force pure. Suivez votre volume, vos records (PR) et planifiez vos objectifs avec Performance ID. L'application ultime pour la musculation.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ url('app_home') }}">
    {# Meta Open Graph #}
    <meta property="og:title" content="Performance ID - Dominez votre Surcharge Progressive">
    <meta property="og:description" content="Suivi de volume, PR et objectifs. L'outil ultime pour briser vos plateaux en musculation.">
    <meta property="og:type" content="website">
{% endblock %}

{% block body %}
<div class="home-wrapper overflow-hidden position-relative" style="min-height: 100vh;">
    
    {# BRANDING TEXTUEL #}
    <div class="top-left-brand">
        <a href="{{ path('app_home') }}" class="text-decoration-none" aria-label="Performance ID Accueil">
            <span class="brand-main">PERFORMANCE</span><span class="brand-accent">ID</span>
        </a>
    </div>

    {# SECTION HERO #}
    <section class="d-flex align-items-center justify-content-center" style="min-height: 100vh; padding-top: 80px;">
        <div class="container text-center">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    {# fetchpriority="high" aide le LCP si c'est l'élément le plus large #}
                    <h1 class="display-2 fw-bold mb-0 text-white main-title text-uppercase">
                        ENTRAÎNEZ-VOUS AVEC
                    </h1>
                    <span class="display-1 fw-bold precision-text text-uppercase d-block">
                        PRÉCISION
                    </span>
                    
                    <div class="description-container mx-auto mt-4 mb-5">
                        <p class="lead text-white hero-description mb-0">
                            Le suivi manuel est terminé. <strong class="text-white">Performance ID</strong> transforme vos données en force pure. 
                            Analysez chaque série, dominez votre surcharge progressive et brisez vos plateaux.
                        </p>
                    </div>

                    {# CTA BUTTONS #}
                    <div class="d-flex flex-column flex-sm-row justify-content-center gap-4">
                        <a href="{{ path('app_register') }}" class="btn btn-danger btn-lg px-5 py-3 fw-bold rounded-1 text-uppercase shadow-red">
                            Commencer maintenant
                        </a>
                        <a href="{{ path('app_login') }}" class="btn btn-light btn-lg px-5 py-3 fw-bold rounded-1 text-uppercase text-dark">
                            Se connecter
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# SECTION FEATURES #}
    <section class="py-5 bg-dark-transparent">
        <div class="container">
            <div class="row g-4 text-center">
                <div class="col-md-4">
                    <article class="feature-card p-4 h-100">
                        <i class="bi bi-graph-up-arrow text-danger fs-1 d-block mb-3" aria-hidden="true"></i>
                        <h2 class="h4 text-white fw-bold">VOLUME</h2>
                        <p class="text-light-custom small">Progression mathématique de vos charges de travail.</p>
                    </article>
                </div>
                <div class="col-md-4">
                    <article class="feature-card p-4 active-feature h-100">
                        <i class="bi bi-fire text-danger fs-1 d-block mb-3" aria-hidden="true"></i>
                        <h2 class="h4 text-white fw-bold">RECORDS</h2>
                        <p class="text-light-custom small">Historique complet de vos Records Personnels (PR).</p>
                    </article>
                </div>
                <div class="col-md-4">
                    <article class="feature-card p-4 h-100">
                        <i class="bi bi-shield-check text-danger fs-1 d-block mb-3" aria-hidden="true"></i>
                        <h2 class="h4 text-white fw-bold">OBJECTIFS</h2>
                        <p class="text-light-custom small">Planification intelligente de vos futurs paliers.</p>
                    </article>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    /* Logo haut gauche */
    .top-left-brand {
        position: absolute;
        top: 25px;
        left: 30px;
        z-index: 1000;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2.2rem;
        letter-spacing: 1px;
    }
    
    .brand-main { color: #ffffff; }
    .brand-accent { color: #ff3131; }

    /* Titres */
    .main-title { 
        font-family: 'Bebas Neue', sans-serif; /* Correction : Utilisation d'une police déjà chargée */
        line-height: 1.0; 
        letter-spacing: -1px;
    }

    .precision-text { 
        font-family: 'Bebas Neue', sans-serif; 
        letter-spacing: 5px; 
        color: transparent;
        -webkit-text-stroke: 2px #ff3131;
        font-size: clamp(3.5rem, 12vw, 9.5rem); 
        line-height: 0.9;
        margin-top: 5px;
    }

    /* Container Description */
    .description-container {
        max-width: 850px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        padding: 30px;
        border-radius: 4px;
        background: rgba(0, 0, 0, 0.85); /* Un peu plus opaque pour le contraste */
        backdrop-filter: blur(10px);
    }

    .hero-description { 
        font-size: 1.25rem; 
        line-height: 1.6;
        color: #ffffff !important; /* Blanc pur pour l'accessibilité */
    }

    /* Feature Cards */
    .feature-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        transition: transform 0.3s ease, background 0.3s ease;
        will-change: transform;
    }

    .feature-card:hover { 
        transform: translateY(-8px); 
        background: rgba(255, 255, 255, 0.07);
    }

    .active-feature { border-color: #ff3131; }
    
    /* Correction contraste Accessibilité : Gris plus clair */
    .text-light-custom { 
        color: rgba(255, 255, 255, 0.9); 
    }

    /* Boutons & Ombres */
    .shadow-red { box-shadow: 0 10px 25px rgba(255, 49, 49, 0.35); }
    .btn-danger { background-color: #ff3131; border: none; transition: 0.2s; }
    .btn-danger:hover { background-color: #d92626; transform: scale(1.02); }

    /* Animations optimisées */
    .main-title, .precision-text, .description-container { 
        animation: fadeInUp 0.6s ease-out forwards; 
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Responsive */
    @media (max-width: 768px) {
        .top-left-brand { top: 15px; left: 20px; font-size: 1.6rem; }
        .btn-lg { width: 100%; padding: 15px !important; }
        .description-container { padding: 20px; margin: 0 15px; }
        .precision-text { -webkit-text-stroke: 1px #ff3131; }
    }
</style>
{% endblock %}