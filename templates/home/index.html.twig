{% extends 'base.html.twig' %}

{# Désactivation de la navbar pour le look cinématique #}
{% block navbar %}{% endblock %}

{% block body %}
{# SECTION HERO #}
<section class="d-flex align-items-center justify-content-center" style="min-height: 85vh;">
    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h1 class="display-2 fw-bold mb-0 text-white" style="line-height: 0.9; letter-spacing: -2px;">
                    ENTRAÎNEZ-VOUS AVEC
                </h1>
                <h2 class="display-1 fw-bold text-danger mb-4" style="font-family: 'Bebas Neue'; -webkit-text-stroke: 1px #dc3545; color: transparent; letter-spacing: 4px;">
                    PRÉCISION
                </h2>
                
                <p class="lead text-white-50 mx-auto mb-5" style="max-width: 600px; font-size: 1.1rem; line-height: 1.6;">
                    Le suivi manuel est terminé. Nous avons conçu <span class="text-white">Performance ID</span> pour les athlètes exigeants. 
                    Analysez chaque série, visualisez votre progression et brisez vos plateaux.
                </p>

                {# BOUTONS RÉTRÉCIS ET STYLISÉS #}
                <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                    <a href="{{ path('app_register') }}" class="btn btn-danger px-4 py-2 fw-bold rounded-0 text-uppercase shadow-lg transition-all" style="letter-spacing: 1px; font-size: 0.9rem;">
                        REJOINDRE
                    </a>
                    <a href="{{ path('app_login') }}" class="btn btn-outline-light px-4 py-2 fw-bold rounded-0 text-uppercase transition-all" style="letter-spacing: 1px; font-size: 0.9rem; border-width: 1px;">
                        CONNEXION
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

{# SECTION SEO & FEATURES #}
<section class="py-5" style="background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.8));">
    <div class="container py-4">
        <div class="row g-5 text-center">
            <div class="col-md-4">
                <div class="p-3">
                    <i class="bi bi-graph-up-arrow text-danger fs-2 mb-3 d-block"></i>
                    <h3 class="h5 mb-3">Suivi du Volume</h3>
                    <p class="small text-white-50">Calculez votre tonnage total par séance pour piloter votre surcharge progressive avec une précision chirurgicale.</p>
                </div>
            </div>
            <div class="col-md-4 border-sm-start border-secondary" style="--bs-border-opacity: .3;">
                <div class="p-3">
                    <i class="bi bi-trophy text-danger fs-2 mb-3 d-block"></i>
                    <h3 class="h5 mb-3">Records (PR)</h3>
                    <p class="small text-white-50">Identifiez instantanément vos records sur chaque exercice et suivez l'évolution de votre force maximale.</p>
                </div>
            </div>
            <div class="col-md-4 border-sm-start border-secondary" style="--bs-border-opacity: .3;">
                <div class="p-3">
                    <i class="bi bi-target text-danger fs-2 mb-3 d-block"></i>
                    <h3 class="h5 mb-3">Objectifs Intelligents</h3>
                    <p class="small text-white-50">Fixez vos paliers de poids cibles et visualisez votre pourcentage de complétion en temps réel.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .transition-all { transition: all 0.3s ease; }
    .btn:hover { transform: translateY(-2px); opacity: 0.9; }
    
    /* Correction responsive pour les bordures */
    @media (max-width: 768px) {
        .col-md-4 { border: none !important; }
        h1 { font-size: 3rem !important; }
        h2 { font-size: 4rem !important; }
    }
</style>
{% endblock %}