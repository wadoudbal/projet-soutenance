{% extends 'base.html.twig' %}

{% block title %}Activer la 2FA{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h2 class="card-title">Sécurisez votre compte</h2>
                    <p class="text-muted">Scannez ce QR Code avec votre application de sécurité (Google Authenticator, Authy, etc.)</p>
                    
                    <div class="my-4 d-flex justify-content-center">
                        {# On remplace la balise <img> par un conteneur vide que le JS va remplir #}
                        <div id="qrcode-container" class="border p-3 bg-white shadow-sm"></div>
                    </div>

                    <div class="mt-3 mb-4">
                        <p class="small text-muted mb-1">Si vous ne pouvez pas scanner, entrez ce code manuellement :</p>
                        <kbd style="font-size: 1.2rem; letter-spacing: 2px;">{{ user.googleAuthenticatorSecret }}</kbd>
                    </div>

                    <div class="alert alert-warning text-start">
                        <strong>Important :</strong> Une fois scanné, votre application générera un code temporaire. Ne désinstallez pas votre application sans avoir désactivé la 2FA ici.
                    </div>

                    <a href="{{ path('app_home') }}" class="btn btn-success w-100">C'est fait, j'ai scanné !</a>
                </div>
            </div>
        </div>
    </div>
</div>

{# Ajout de la bibliothèque pour générer le QR Code en local #}
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
    // On récupère le contenu brut généré par le bundle
    var qrContent = "{{ qrCodeContent|raw }}";
    
    if (qrContent) {
        new QRCode(document.getElementById("qrcode-container"), {
            text: qrContent,
            width: 200,
            height: 200,
            colorDark : "#000000",
            colorLight : "#ffffff",
            correctLevel : QRCode.CorrectLevel.H
        });
    }
</script>
{% endblock %}