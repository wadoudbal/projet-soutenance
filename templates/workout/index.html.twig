{% extends 'base.html.twig' %}

{% block title %}Performance ID - Historique{% endblock %}

{% block body %}
<style>
    :root {
        --sidebar-width: 280px;
        --primary-red: #ff3131;
    }

    .bebas { font-family: 'Bebas Neue', cursive; letter-spacing: 1px; }

    /* Structure Globale */
    .dashboard-container {
        display: flex;
        min-height: 100vh;
    }

    /* --- SIDEBAR (Copie conforme Dashboard) --- */
    .sidebar {
        width: var(--sidebar-width);
        background: rgba(10, 10, 10, 0.95);
        backdrop-filter: blur(15px);
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        flex-direction: column;
        padding: 2rem 1.5rem;
        position: fixed;
        height: 100vh;
        z-index: 100;
    }

    .sidebar-brand {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2rem;
        color: #fff;
        text-decoration: none;
        margin-bottom: 3rem;
        text-align: center;
    }

    .nav-link-custom {
        display: flex;
        align-items: center;
        color: #aaa;
        text-decoration: none;
        padding: 1rem;
        margin-bottom: 0.5rem;
        border-radius: 8px;
        transition: 0.3s;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.9rem;
    }

    .nav-link-custom i { font-size: 1.2rem; margin-right: 15px; }

    .nav-link-custom:hover, .nav-link-custom.active {
        background: rgba(255, 49, 49, 0.1);
        color: var(--primary-red);
    }

    /* --- CONTENU PRINCIPAL --- */
    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        padding: 3rem;
        width: calc(100% - var(--sidebar-width));
    }

    /* Styles spécifiques Historique */
    .glass-search {
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(15px);
        border: 1px solid var(--primary-red);
        padding: 20px;
        margin-bottom: 40px;
    }

    .date-header {
        display: flex;
        align-items: center;
        margin-top: 30px;
        margin-bottom: 15px;
    }
    
    .date-header h3 {
        background: var(--primary-red);
        color: white;
        padding: 5px 15px;
        font-size: 1.1rem;
    }

    .date-header hr {
        flex-grow: 1;
        border-color: var(--primary-red);
        opacity: 0.5;
        margin-left: 20px;
    }

    .workout-row {
        background: rgba(15, 15, 15, 0.9) !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: 0.3s;
        margin-bottom: 10px;
        color: white;
    }

    .workout-row:hover {
        background: rgba(30, 30, 30, 1) !important;
        border-color: var(--primary-red);
    }

    .stat-label {
        font-size: 0.75rem;
        color: #bbbbbb; 
        text-transform: uppercase;
        font-weight: bold;
        display: block;
    }

    .stat-data {
        font-family: 'Bebas Neue';
        font-size: 1.6rem;
        color: #ffffff;
    }

    .text-warning-custom { color: #ffc107 !important; }

    @media (max-width: 992px) {
        .sidebar { width: 80px; padding: 2rem 0.5rem; }
        .sidebar-brand span, .nav-link-custom span { display: none; }
        .main-content { margin-left: 80px; width: calc(100% - 80px); padding: 1.5rem; }
        .nav-link-custom { justify-content: center; }
        .nav-link-custom i { margin: 0; }
    }
</style>

<div class="dashboard-container">
    {# --- SIDEBAR --- #}
    <nav class="sidebar">
        <a href="{{ path('app_home') }}" class="sidebar-brand">
            PERFORMANCE <span style="color: var(--primary-red)">ID</span>
        </a>

        <div class="nav-menu">
            <a href="{{ path('app_home') }}" class="nav-link-custom">
                <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
            </a>
            <a href="{{ path('app_workout_index') }}" class="nav-link-custom active">
                <i class="bi bi-calendar-check"></i> <span>Historique</span>
            </a>
            <a href="{{ path('app_goal_new') }}" class="nav-link-custom">
                <i class="bi bi-trophy"></i> <span>Objectifs</span>
            </a>
            <a href="#" class="nav-link-custom">
                <i class="bi bi-person-circle"></i> <span>Mon Profil</span>
            </a>
        </div>

        <div class="mt-auto">
            <hr style="border-color: rgba(255,255,255,0.1)">
            <a href="{{ path('app_logout') }}" class="nav-link-custom text-danger">
                <i class="bi bi-box-arrow-left"></i> <span>Déconnexion</span>
            </a>
        </div>
    </nav>

    {# --- CONTENU DE L'HISTORIQUE --- #}
    <main class="main-content">
        <div class="mb-5">
            <h4 class="text-danger mb-0 bebas" style="letter-spacing: 3px;">HISTORIQUE D'ENTRAÎNEMENT</h4>
            <h1 class="bebas display-3 m-0 text-white">JOURNAL <span class="text-danger">PERSONNEL</span></h1>
        </div>

        {# BARRE DE RECHERCHE #}
        <div class="glass-search shadow-lg">
            <form method="get" class="row g-2">
                <div class="col-md-10">
                    <input type="text" name="q" class="form-control bg-dark text-white border-secondary py-2" 
                           placeholder="Rechercher un exercice..." value="{{ searchTerm }}">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-danger w-100 bebas fs-5">FILTRER</button>
                </div>
            </form>
        </div>

        {# LISTE DES SÉANCES #}
        {% set last_date = null %}
        {% for workout in workouts %}
            {% if workout.createdAt|date('d/m/Y') != last_date %}
                <div class="date-header">
                    <h3 class="bebas m-0">
                        <i class="bi bi-calendar-check me-2"></i>{{ workout.createdAt|date('d F Y') }}
                    </h3>
                    <hr>
                </div>
                {% set last_date = workout.createdAt|date('d/m/Y') %}
            {% endif %}

            <div class="card workout-row shadow-lg">
                <div class="card-body py-3">
                    <div class="row align-items-center">
                        <div class="col-md-1 border-end border-secondary">
                            <span class="text-white fw-bold">{{ workout.createdAt|date('H:i') }}</span>
                        </div>

                        <div class="col-md-4 ps-4">
                            <div class="bebas h4 mb-0 text-white">{{ workout.exercise.name }}</div>
                            <small class="text-danger fw-bold text-uppercase" style="font-size: 0.7rem;">
                                {{ workout.name|default('Série standard') }}
                            </small>
                        </div>

                        <div class="col-md-5">
                            <div class="row">
                                <div class="col-4 text-center">
                                    <span class="stat-label">Série</span>
                                    <span class="stat-data">{{ workout.serie }}</span>
                                </div>
                                <div class="col-4 text-center border-start border-end border-secondary">
                                    <span class="stat-label">Charge</span>
                                    <span class="stat-data text-warning-custom">{{ workout.weight }} KG</span>
                                </div>
                                <div class="col-4 text-center">
                                    <span class="stat-label">Reps</span>
                                    <span class="stat-data">{{ workout.reps }}</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-2 text-end">
                            <div class="d-flex justify-content-end align-items-center">
                                <a href="{{ path('app_workout_edit', {'id': workout.id}) }}" class="btn btn-outline-info btn-sm me-2">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                {{ include('workout/_delete_form.html.twig') }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="text-center py-5 bg-dark bg-opacity-50 rounded">
                <p class="text-white bebas h4">Aucune séance enregistrée pour le moment.</p>
            </div>
        {% endfor %}
    </main>
</div>
{% endblock %}