<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        {# Indispensable pour que le mobile ne dézoome pas le site #}
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        
        {# SEO : Titre et Description dynamiques #}
        <title>{% block title %}Performance ID - Suivi de Performance Sportive{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}Optimisez vos entraînements avec Performance ID. Suivi de volume, gestion des records et objectifs de force athlétique.{% endblock %}">
        
        {# Open Graph (pour que le partage sur réseaux sociaux soit beau) #}
        <meta property="og:title" content="Performance ID">
        <meta property="og:description" content="Atteignez vos sommets sportifs avec notre outil de suivi de performance.">
        <meta property="og:type" content="website">

        {# Préconnexion pour gagner du temps sur le chargement des polices #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

        {# CSS #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
        
        <style>
            :root { 
                --primary-red: #dc3545; 
                --glass-bg: rgba(0, 0, 0, 0.85); 
            }

            body { 
                background-color: #000;
                color: #ffffff;
                font-family: 'Roboto', sans-serif;
                min-height: 100vh;
                margin: 0;
                /* Évite le scroll horizontal bizarre sur certains mobiles */
                overflow-x: hidden;
            }

            .bg-global {
                position: fixed;
                inset: 0;
                /* On assombrit un peu plus le gradient pour la lisibilité sur petit écran */
                background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.95)), 
                            url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=60&w=1400&auto=format&fit=crop');
                background-size: cover;
                background-position: center;
                z-index: -1;
            }

            /* --- RESPONSIVE OPTIMISATION --- */
            @media (max-width: 991px) {
                .navbar-collapse {
                    background: var(--glass-bg);
                    padding: 1rem;
                    border-radius: 8px;
                    margin-top: 10px;
                }
                .nav-link { margin: 10px 0 !important; }
            }

            @media (max-width: 576px) {
                .navbar-brand { font-size: 1.5rem; }
                /* On réduit la lourdeur du background sur mobile pour la performance (SEO) */
                .bg-global { background-attachment: scroll; } 
            }
            
            .navbar { 
                background-color: var(--glass-bg) !important;
                backdrop-filter: blur(15px);
                -webkit-backdrop-filter: blur(15px);
                border-bottom: 1px solid rgba(220, 53, 69, 0.3);
                padding: 0.7rem 0;
            }
            
            .navbar-brand { 
                font-family: 'Bebas Neue', cursive; 
                letter-spacing: 1px;
                color: #fff !important;
            }
            .navbar-brand span { color: var(--primary-red); }

            .nav-link { 
                font-family: 'Bebas Neue', cursive; 
                text-transform: uppercase; 
                letter-spacing: 1.2px;
                color: rgba(255, 255, 255, 0.8) !important;
                transition: color 0.2s ease;
            }
            .nav-link:hover, .nav-link.active { color: var(--primary-red) !important; }

            .btn-nav {
                font-family: 'Bebas Neue', cursive;
                letter-spacing: 1px;
                text-transform: uppercase;
                border-radius: 0; /* Style plus agressif / sport */
            }

            /* Pour éviter que le contenu ne colle aux bords sur mobile */
            main {
                padding-top: 2rem;
                padding-bottom: 4rem;
            }

            h1, h2, h3, h4 { font-family: 'Bebas Neue', cursive; text-transform: uppercase; }

            /* Animation fluide pour les alertes */
            .alert { border-radius: 0; border-left: 5px solid; }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div class="bg-global" aria-hidden="true"></div>

        <nav class="navbar navbar-expand-lg navbar-dark sticky-top" role="navigation">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">PERFORMANCE<span>ID</span></a>
                
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <div class="navbar-nav ms-auto align-items-center">
                        {% if app.user %}
                            <a class="nav-link" href="{{ path('app_dashboard') }}">Dashboard</a>
                            <a class="nav-link" href="{{ path('app_workout_index') }}">
                                <i class="bi bi-clock-history me-1 d-none d-lg-inline"></i> Historique
                            </a>
                            <a class="nav-link" href="{{ path('app_profile') }}">
                                <i class="bi bi-person-circle me-1 d-none d-lg-inline"></i> Profil
                            </a>
                            <a class="btn btn-nav btn-outline-light btn-sm ms-lg-3 mt-3 mt-lg-0 px-3" href="{{ path('app_logout') }}">Déconnexion</a>
                        {% else %}
                            <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
                            <a class="btn btn-nav btn-danger ms-lg-3 px-4 py-2 mt-3 mt-lg-0 shadow" href="{{ path('app_register') }}">S'INSCRIRE</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        {# Zone de notification (Flashes) indispensable pour l'UX #}
        <div class="container mt-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }} bg-dark text-white border-{{ label == 'danger' ? 'danger' : 'success' }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <main id="main-content">
            {% block body %}{% endblock %}
        </main>

        {# Footer minimaliste pour le SEO #}
        <footer class="py-4 text-center border-top border-secondary mt-auto" style="background: rgba(0,0,0,0.5);">
            <p class="small text-white-50 mb-0">&copy; {{ "now"|date("Y") }} PERFORMANCE ID. Dominez vos limites.</p>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>