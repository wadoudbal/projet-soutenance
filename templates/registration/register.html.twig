{% extends 'base.html.twig' %}

{% block navbar %}{% endblock %}

{% block title %}Créer un profil | Performance ID{% endblock %}

{% block body %}
<style>
    :root { --primary: #ff3131; --bg-dark: #0f0f0f; }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #050505; /* Fond solide plus rapide que des dégradés/images */
    }

    .auth-card {
        width: 100%;
        max-width: 480px;
        margin: 1.5rem;
        padding: 2.5rem;
        background: var(--bg-dark); 
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-top: 4px solid var(--primary);
        box-shadow: 0 15px 35px rgba(0,0,0,0.9);
        border-radius: 4px;
        animation: fadeIn 0.3s ease-out; /* Animation plus courte */
    }

    .auth-h1 {
        font-family: 'Bebas Neue', Impact, sans-serif;
        font-size: 2.8rem;
        color: #fff;
        text-align: center;
        margin: 0;
        letter-spacing: 2px;
    }

    .auth-sub {
        display: block;
        text-align: center;
        color: var(--primary);
        font-weight: 800;
        margin-bottom: 2rem;
        font-size: 0.75rem;
        letter-spacing: 4px;
    }

    .form-label {
        color: rgba(255,255,255,0.7); 
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        margin-bottom: 0.4rem;
        display: block;
    }

    .form-input {
        width: 100%;
        padding: 0.85rem;
        background: #1a1a1a !important; /* Fond plus opaque pour meilleure visibilité */
        border: 1px solid #333;
        color: #ffffff !important;
        border-radius: 0; /* Look plus agressif/sport */
        transition: border-color 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: var(--primary);
        background: #222 !important;
    }

    .password-wrapper { position: relative; display: flex; align-items: center; }

    .toggle-password {
        position: absolute;
        right: 12px;
        background: none;
        border: none;
        cursor: pointer;
        color: #666;
    }

    .btn-submit {
        width: 100%;
        padding: 1.1rem;
        background: var(--primary);
        color: #fff;
        border: none;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.4rem;
        letter-spacing: 1px;
        margin-top: 1.5rem;
        cursor: pointer;
        transition: transform 0.1s, filter 0.2s;
    }

    .btn-submit:hover { filter: brightness(1.1); }
    .btn-submit:active { transform: scale(0.98); }

    .auth-footer { margin-top: 1.5rem; text-align: center; color: #777; font-size: 0.85rem; }
    .auth-footer a { color: #fff; font-weight: 800; text-decoration: none; border-bottom: 1px solid var(--primary); }

    .checkbox-container {
        display: flex;
        align-items: center;
        gap: 12px;
        color: #bbb;
        font-size: 0.85rem;
        margin-top: 1.2rem;
        padding: 10px;
        background: rgba(255,255,255,0.03);
    }

    .checkbox-container input { width: 18px; height: 18px; accent-color: var(--primary); }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>

<main class="auth-wrapper">
    <article class="auth-card">
        <header>
            <h1 class="auth-h1">PERFORMANCE <span style="color:var(--primary)">ID</span></h1>
            <span class="auth-sub">REJOINDRE L'ÉLITE</span>
        </header>

        {{ form_start(registrationForm) }}
            <div class="row g-2">
                <div class="col-6">
                    <label class="form-label">Prénom</label>
                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-input'}}) }}
                </div>
                <div class="col-6">
                    <label class="form-label">Nom</label>
                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-input'}}) }}
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label">Email</label>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-input'}}) }}
            </div>

            <div class="mt-3">
                <label class="form-label">Mot de passe</label>
                <div class="password-wrapper">
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-input', 'placeholder': '••••••••'}}) }}
                    <button type="button" id="toggleRegPassword" class="toggle-password">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
            </div>

            <div class="checkbox-container">
                {# On désactive le label auto de Symfony pour éviter le doublon #}
                {{ form_widget(registrationForm.agreeTerms, {'label': false}) }}
                <label for="{{ registrationForm.agreeTerms.vars.id }}" style="margin:0; cursor:pointer;">
                    J'accepte les conditions d'utilisation
                </label>
            </div>

            <button type="submit" class="btn-submit">Créer mon compte</button>
        {{ form_end(registrationForm) }}

        <footer class="auth-footer">
            <p>Déjà inscrit ? <a href="{{ path('app_login') }}">SE CONNECTER</a></p>
            <a href="{{ path('app_home') }}" style="color: #555; margin-top: 1rem; display: inline-block;">← Retour</a>
        </footer>
    </article>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const btn = document.getElementById('toggleRegPassword');
        const input = document.getElementById('{{ registrationForm.plainPassword.vars.id }}');
        const icon = document.getElementById('eyeIcon');

        if(btn && input) {
            btn.addEventListener('click', function() {
                const isPass = input.type === 'password';
                input.type = isPass ? 'text' : 'password';
                icon.className = isPass ? 'bi bi-eye-slash' : 'bi bi-eye';
                icon.style.color = isPass ? '#ff3131' : '#666';
            });
        }
    });
</script>
{% endblock %}