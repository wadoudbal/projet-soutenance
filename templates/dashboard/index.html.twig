{% extends 'base.html.twig' %}

{% block body %}
<div class="container">
    {# 1. ACCUEIL #}
    <div class="row mb-5 align-items-center">
        <div class="col-md-8 text-center text-md-start">
            <h1 class="display-4 fw-bold text-white">SALUT, {{ app.user.userIdentifier|split('@')[0]|upper }}</h1>
            <p class="text-danger fw-bold text-uppercase mb-4 mb-md-0" style="letter-spacing: 2px;">Prêt pour ta prochaine performance ?</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a href="{{ path('app_workout_new') }}" class="btn btn-danger btn-lg w-100 w-md-auto fw-bold rounded-0 shadow-lg">
                <i class="bi bi-plus-circle me-2"></i>ENREGISTRER UNE SÉANCE
            </a>
        </div>
    </div>

    {# 2. BLOC OBJECTIF #}
    {% if goal %}
    <div class="row mb-5">
        <div class="col-12">
            <div class="p-4" style="background: rgba(0,0,0,0.6); border: 1px solid rgba(220, 53, 69, 0.3); backdrop-filter: blur(10px);">
                <div class="d-flex justify-content-between align-items-end mb-3">
                    <div>
                        <h5 class="text-white-50 small text-uppercase mb-1">Objectif : {{ goal.exercise.name }}</h5>
                        <h2 class="text-white m-0">{{ goal.targetWeight }} KG</h2>
                    </div>
                    <div class="text-danger fw-bold fs-4">{{ pourcentage|round }}%</div>
                </div>
                
                <div class="progress" style="height: 12px; background: rgba(255,255,255,0.1); border-radius: 0;">
                    <div class="progress-bar bg-danger" id="js-progress-bar" role="progressbar" 
                         aria-valuenow="{{ pourcentage }}" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                
                <div class="d-flex justify-content-between mt-2 small text-white-50">
                    <span>Record : <strong>{{ recordAbsolu }} kg</strong></span>
                    <span>Cible : <strong>{{ goal.targetWeight }} kg</strong></span>
                </div>
            </div>
        </div>
    </div>
    {% else %}
    <div class="row mb-5">
        <div class="col-12">
            <a href="{{ path('app_goal_new') }}" class="btn btn-outline-secondary w-100 py-4 border-dashed text-uppercase">
                <i class="bi bi-trophy me-2"></i> Aucun objectif défini - Clique ici pour en fixer un
            </a>
        </div>
    </div>
    {% endif %}

    {# 3. STATS #}
    <div class="row g-4">
        {% set stats = [
            {'label': 'Volume Total', 'val': volumeTotal|number_format(0, ',', ' '), 'unit': 'KG'},
            {'label': 'Séances / Semaine', 'val': seancesSemaine, 'unit': 'FOIS'},
            {'label': 'Record Absolu', 'val': recordAbsolu, 'unit': 'KG'}
        ] %}
        {% for stat in stats %}
        <div class="col-md-4">
            <div class="p-4 h-100" style="background: rgba(0,0,0,0.6); border-left: 4px solid #dc3545;">
                <div class="text-white-50 small text-uppercase fw-bold mb-2">{{ stat.label }}</div>
                <div class="h1 m-0 text-white font-bebas" style="font-size: 3rem;">
                    {{ stat.val }} <span class="fs-5">{{ stat.unit }}</span>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const bar = document.getElementById('js-progress-bar');
        if(bar) {
            setTimeout(() => { bar.style.width = "{{ pourcentage }}%"; }, 200);
        }
    });
</script>
{% endblock %}