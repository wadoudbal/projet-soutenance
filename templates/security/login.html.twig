{% extends 'base.html.twig' %}

{# --- SUPPRESSION DE LA NAVBAR SUR CETTE PAGE --- #}
{% block navbar %}{% endblock %}

{# --- SEO CRITIQUE --- #}
{% block meta_tags %}
    <meta name="description" content="Connectez-vous à Performance ID. Accédez à votre suivi d'entraînement, vos analyses de santé et vos statistiques de performance sportive.">
    <meta name="keywords" content="sport, performance, musculation, imc, suivi, athlète">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ app.request.uri }}">
{% endblock %}

{% block title %}Connexion Athlète | Performance ID{% endblock %}

{% block body %}
<style>
    /* PERFORMANCE : Priorité au rendu (Critical CSS) */
    :root {
        --primary: #dc3545;
        --dark-bg: #0a0a0a;
    }

    /* SEO & ACCESSIBILITÉ */
    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
    }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--dark-bg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        position: relative;
        overflow: hidden;
    }

    /* PERFORMANCE : Optimisation de l'image */
    .auth-bg {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(rgba(0,0,0,0.85), rgba(0,0,0,0.95)), 
                    url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=20&w=1200&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
    }

    .auth-card {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 400px;
        margin: 20px;
        padding: 40px;
        background: rgba(17, 17, 17, 0.9);
        border-top: 4px solid var(--primary);
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        backdrop-filter: blur(10px);
    }

    .auth-h1 {
        font-family: 'Bebas Neue', Impact, sans-serif;
        font-size: 3rem;
        color: #fff;
        text-align: center;
        margin: 0 0 5px 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .auth-sub {
        display: block;
        text-align: center;
        color: var(--primary);
        font-weight: bold;
        letter-spacing: 2px;
        margin-bottom: 30px;
        font-size: 0.8rem;
    }

    .form-group { margin-bottom: 20px; }

    .form-label {
        display: block;
        color: #bbb;
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .form-input {
        width: 100%;
        padding: 12px;
        background: #222;
        border: 1px solid #333;
        color: #fff;
        font-size: 1rem;
        border-radius: 2px;
        transition: all 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: var(--primary);
        background: #282828;
    }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 2px;
        font-weight: bold;
        font-size: 1rem;
        cursor: pointer;
        transition: transform 0.2s, background 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-submit:hover { 
        background: #bd2130;
        transform: translateY(-1px);
    }

    .error-box {
        background: #2d1212;
        color: #ff8080;
        padding: 12px;
        border-left: 4px solid var(--primary);
        margin-bottom: 20px;
        font-size: 0.85rem;
    }

    .auth-footer {
        margin-top: 25px;
        text-align: center;
        font-size: 0.85rem;
        color: #666;
    }

    .auth-footer a { color: #fff; font-weight: bold; text-decoration: none; transition: color 0.2s; }
    .auth-footer a:hover { color: var(--primary); }
</style>

<main class="auth-wrapper">
    <div class="auth-bg" role="presentation"></div>

    <article class="auth-card">
        <header>
            <h1 class="auth-h1">Performance <span style="color:var(--primary)">ID</span></h1>
            <span class="auth-sub">ACCÈS SÉCURISÉ</span>
        </header>

        <form method="post" action="{{ path('app_login') }}">
            {% if error %}
                <div class="error-box" role="alert">
                    Identifiants invalides. Veuillez réessayer.
                </div>
            {% endif %}

            <div class="form-group">
                <label for="username" class="form-label">Email</label>
                <input type="email" value="{{ last_username }}" name="email" id="username" class="form-input" autocomplete="email" required autofocus placeholder="athlète@exemple.com">
            </div>

            <div class="form-group">
                <label for="password" class="form-label">Mot de passe</label>
                <input type="password" name="password" id="password" class="form-input" autocomplete="current-password" required placeholder="••••••••">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn-submit">
                SE CONNECTER
            </button>
        </form>

        <footer class="auth-footer">
            <p>Nouveau ici ? <a href="{{ path('app_register') }}">REJOINDRE L'ÉLITE</a></p>
            <a href="{{ path('app_home') }}" style="font-size: 0.75rem; color: #444; margin-top: 15px; display: inline-block;">Retour à l'accueil</a>
        </footer>
    </article>
</main>
{% endblock %}