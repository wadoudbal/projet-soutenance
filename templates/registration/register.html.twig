{% extends 'base.html.twig' %}

{% block title %}Créer un profil - Performance ID{% endblock %}

{% block body %}
<style>
    .page-bg {
        background: linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.8)), 
                    url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=2070&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 100vh;
        width: 100vw;
        position: absolute;
        top: 0;
        left: 0;
        z-index: -1;
    }

    .register-container {
        margin-top: 5vh;
        margin-bottom: 5vh;
    }

    .form-control {
        background-color: #2b2b2b !important;
        border: 1px solid #444 !important;
        color: #fff !important;
        border-radius: 0 !important;
    }

    .form-control:focus {
        border-color: #ff4d4d !important;
        box-shadow: none !important;
    }

    .input-group-text {
        background-color: #2b2b2b;
        border: 1px solid #444;
        color: #888;
        border-radius: 0;
        cursor: pointer;
    }

    .input-group-text:hover {
        color: #ff4d4d;
    }
</style>

<div class="page-bg"></div>

<div class="row justify-content-center register-container">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark text-white border-0 shadow-lg">
            <div class="card-header bg-danger text-center py-3 border-0">
                <h1 class="h3 mb-0 fw-bold text-uppercase">Créer un profil</h1>
            </div>

            <div class="card-body p-4">
                {{ form_start(registrationForm) }}
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="small text-uppercase fw-bold mb-1">Prénom</label>
                            {{ form_widget(registrationForm.firstName, {'attr': {'placeholder': 'Jean'}}) }}
                            <div class="text-danger small">{{ form_errors(registrationForm.firstName) }}</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small text-uppercase fw-bold mb-1">Nom</label>
                            {{ form_widget(registrationForm.lastName, {'attr': {'placeholder': 'Dupont'}}) }}
                            <div class="text-danger small">{{ form_errors(registrationForm.lastName) }}</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="small text-uppercase fw-bold mb-1">Email</label>
                        {{ form_widget(registrationForm.email, {'attr': {'placeholder': 'email@exemple.com'}}) }}
                        <div class="text-danger small">{{ form_errors(registrationForm.email) }}</div>
                    </div>

                    <div class="mb-3">
                        <label class="small text-uppercase fw-bold mb-1">Mot de passe</label>
                        <div class="input-group">
                            {{ form_widget(registrationForm.plainPassword, {
                                'attr': {
                                    'placeholder': '••••••••',
                                    'id': 'password-field'
                                }
                            }) }}
                            <span class="input-group-text" id="togglePassword">
                                <i class="bi bi-eye-fill" id="eyeIcon"></i>
                            </span>
                        </div>
                        <div class="text-danger small">{{ form_errors(registrationForm.plainPassword) }}</div>
                    </div>

                    <div class="mb-4 form-check">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                        <label class="form-check-label small opacity-75">J'accepte les conditions d'utilisation</label>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-danger btn-lg fw-bold text-uppercase rounded-0">
                            Créer mon profil
                        </button>
                    </div>
                {{ form_end(registrationForm) }}

                <div class="mt-3 text-center">
                    <p class="small text-muted">Déjà inscrit ? <a href="{{ path('app_login') }}" class="text-danger fw-bold text-decoration-none">Connexion</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
        // On récupère l'input password (attention à l'ID généré par Symfony)
        // Par défaut Symfony génère registration_form_plainPassword
        const passwordInput = document.querySelector('input[type="password"]') || document.querySelector('input[type="text"][id*="plainPassword"]');
        const eyeIcon = document.getElementById('eyeIcon');
        
        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            eyeIcon.classList.remove('bi-eye-fill');
            eyeIcon.classList.add('bi-eye-slash-fill');
        } else {
            passwordInput.type = 'password';
            eyeIcon.classList.remove('bi-eye-slash-fill');
            eyeIcon.classList.add('bi-eye-fill');
        }
    });
</script>
{% endblock %}