{% extends 'base.html.twig' %}

{# On désactive la navbar globale si elle est dans base.html.twig pour utiliser notre Sidebar #}
{% block navbar %}{% endblock %}

{% block body %}
<style>
    :root {
        --sidebar-width: 280px;
        --primary-red: #ff3131;
    }

    /* Structure Flexbox pour aligner Sidebar et Contenu */
    .dashboard-container {
        display: flex;
        min-height: 100vh;
        background: transparent; /* Pour voir l'image du base.html.twig */
    }

    /* SIDEBAR ALIGNÉE À GAUCHE */
    .sidebar {
        width: var(--sidebar-width);
        background: rgba(10, 10, 10, 0.95);
        backdrop-filter: blur(15px);
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        flex-direction: column;
        padding: 2rem 1.5rem;
        position: fixed; /* Reste fixe au scroll */
        height: 100vh;
        z-index: 100;
    }

    .sidebar-brand {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2rem;
        color: #fff;
        text-decoration: none;
        margin-bottom: 3rem;
        text-align: center;
    }

    .nav-link-custom {
        display: flex;
        align-items: center;
        color: #aaa;
        text-decoration: none;
        padding: 1rem;
        margin-bottom: 0.5rem;
        border-radius: 8px;
        transition: 0.3s;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.9rem;
    }

    .nav-link-custom i { font-size: 1.2rem; margin-right: 15px; }

    .nav-link-custom:hover, .nav-link-custom.active {
        background: rgba(255, 49, 49, 0.1);
        color: var(--primary-red);
    }

    /* ZONE DE CONTENU À DROITE */
    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width); /* Laisse la place à la sidebar */
        padding: 3rem;
        width: calc(100% - var(--sidebar-width));
    }

    /* On garde tes styles de cartes mais on les épure */
    .glass-card {
        background: rgba(0, 0, 0, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        padding: 2rem;
        height: 100%;
    }

    .progress {
        height: 8px;
        background: rgba(255,255,255,0.1);
        border-radius: 10px;
        overflow: hidden;
    }

    @media (max-width: 992px) {
        .sidebar { width: 80px; padding: 2rem 0.5rem; }
        .sidebar-brand span, .nav-link-custom span { display: none; }
        .main-content { margin-left: 80px; width: calc(100% - 80px); padding: 1.5rem; }
        .nav-link-custom { justify-content: center; }
        .nav-link-custom i { margin: 0; }
    }
</style>

<div class="dashboard-container">
    {# --- SIDEBAR NAVIGATION CORRIGÉE --- #}
    <nav class="sidebar">
        <a href="{{ path('app_dashboard') }}" class="sidebar-brand">
            PERFORMANCE <span style="color: var(--primary-red)">ID</span>
        </a>

        <div class="nav-menu">
            {# Dashboard #}
            <a href="{{ path('app_dashboard') }}" class="nav-link-custom {{ app.request.get('_route') == 'app_dashboard' ? 'active' : '' }}">
                <i class="bi bi-speedometer2"></i> <span>Tableau de bord</span>
            </a>

            {# Historique (Entraînements) #}
            <a href="{{ path('app_workout_index') }}" class="nav-link-custom {{ app.request.get('_route') == 'app_workout_index' ? 'active' : '' }}">
                <i class="bi bi-calendar-check"></i> <span>Historique</span>
            </a>

            {# Objectifs #}
            <a href="{{ path('app_goal_new') }}" class="nav-link-custom {{ app.request.get('_route') == 'app_goal_new' ? 'active' : '' }}">
                <i class="bi bi-trophy"></i> <span>Objectifs</span>
            </a>

            {# Profil #}
            <a href="{{ path('app_profile') }}" class="nav-link-custom {{ app.request.get('_route') == 'app_profile' ? 'active' : '' }}">
                <i class="bi bi-person-circle"></i> <span>Mon Profil</span>
            </a>
        </div>

        <div class="mt-auto">
            <hr style="border-color: rgba(255,255,255,0.1)">
            {# Déconnexion #}
            <a href="{{ path('app_logout') }}" class="nav-link-custom text-danger" onclick="return confirm('Se déconnecter ?')">
                <i class="bi bi-box-arrow-left"></i> <span>Déconnexion</span>
            </a>
        </div>
    </nav>

    {# --- CONTENU PRINCIPAL --- #}
    <main class="main-content">
        {# 1. HEADER #}
        <div class="row mb-5 align-items-center">
    <div class="col-md-8">
        {# On utilise app.user.firstName au lieu de userIdentifier #}
        <h1 class="display-5 fw-bold text-white">SALUT, {{ app.user.firstName|upper }}</h1>
        <p class="text-danger fw-bold text-uppercase" style="letter-spacing: 2px;">Prêt pour ta prochaine performance ?</p>
    </div>
            <div class="col-md-4 text-md-end">
                <a href="{{ path('app_workout_new') }}" class="btn btn-danger btn-lg fw-bold rounded-0 shadow-lg px-4">
                    <i class="bi bi-plus-circle me-2"></i>SÉANCE
                </a>
            </div>
        </div>

        {# 2. BLOC OBJECTIF #}
        {% if goal %}
        <div class="row mb-5">
            <div class="col-12">
                <div class="glass-card" style="border-left: 4px solid var(--primary-red);">
                    <div class="d-flex justify-content-between align-items-end mb-3">
                        <div>
                            <h5 class="text-white-50 small text-uppercase mb-1">Objectif : {{ goal.exercise.name }}</h5>
                            <h2 class="text-white m-0" style="font-family: 'Bebas Neue'; font-size: 2.5rem;">{{ goal.targetWeight }} KG</h2>
                        </div>
                        <div class="text-danger fw-bold fs-3">{{ pourcentage|round }}%</div>
                    </div>
                    
                    <div class="progress">
                        <div class="progress-bar bg-danger" id="js-progress-bar" role="progressbar" 
                             style="width: 0%; transition: width 1s ease-in-out;"
                             aria-valuenow="{{ pourcentage }}" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    
                    <div class="d-flex justify-content-between mt-3 small text-white-50">
                        <span>Record Actuel : <strong class="text-white">{{ recordAbsolu }} kg</strong></span>
                        <span>Cible : <strong class="text-white">{{ goal.targetWeight }} kg</strong></span>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="row mb-5">
            <div class="col-12">
                <a href="{{ path('app_goal_new') }}" class="btn btn-outline-secondary w-100 py-4 border-dashed text-uppercase text-white">
                    <i class="bi bi-trophy me-2"></i> Aucun objectif défini - Clique ici pour en fixer un
                </a>
            </div>
        </div>
        {% endif %}

        {# 3. STATS #}
        <div class="row g-4">
            <div class="col-md-4">
                <div class="glass-card">
                    <div class="text-white-50 small text-uppercase fw-bold mb-2">Volume Total</div>
                    <div class="h1 m-0 text-white font-bebas" style="font-size: 3rem;">
                        {{ volumeTotal|number_format(0, ',', ' ') }} <span class="fs-5 text-danger">KG</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card">
                    <div class="text-white-50 small text-uppercase fw-bold mb-2">Séances / Semaine</div>
                    <div class="h1 m-0 text-white font-bebas" style="font-size: 3rem;">
                        {{ seancesSemaine }} <span class="fs-5 text-danger">FOIS</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card">
                    <div class="text-white-50 small text-uppercase fw-bold mb-2">Record Absolu</div>
                    <div class="h1 m-0 text-white font-bebas" style="font-size: 3rem;">
                        {{ recordAbsolu }} <span class="fs-5 text-danger">KG</span>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const bar = document.getElementById('js-progress-bar');
        if(bar) {
            // Animation fluide de la barre
            setTimeout(() => { bar.style.width = "{{ pourcentage }}%"; }, 300);
        }
    });
</script>
{% endblock %}