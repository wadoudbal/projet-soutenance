{% extends 'base.html.twig' %}

{% block title %}Catalogue des exercices{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1> Catalogue des exercices</h1>
        
        {# SEUL L'ADMIN PEUT VOIR LE BOUTON AJOUTER #}
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_exercise_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Ajouter un exercice
            </a>
        {% endif %}
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nom de l'exercice</th>
                        <th>Groupe Musculaire</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for exercise in exercises %}
                    <tr>
                        <td>{{ exercise.id }}</td>
                        <td class="fw-bold text-uppercase">{{ exercise.name }}</td>
                        <td>
                            <span class="badge bg-secondary">{{ exercise.muscleGroup }}</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm">
                                <a href="{{ path('app_exercise_show', {'id': exercise.id}) }}" class="btn btn-sm btn-outline-info">Voir</a>
                                
                                {# PROTECTION DES BOUTONS DE MODIFICATION #}
                                {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('app_exercise_edit', {'id': exercise.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            Aucun exercice trouvé dans le catalogue.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# BOUTON RETOUR POUR L'UTILISATEUR #}
    <div class="mt-3">
        <a href="{{ path('app_workout_index') }}" class="text-decoration-none text-muted">
            ← Retour à mes séances
        </a>
    </div>
{% endblock %}