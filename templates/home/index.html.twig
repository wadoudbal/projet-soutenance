{% extends 'base.html.twig' %}

{% block title %}Performance ID - Dépassez vos limites{% endblock %}

{% block body %}
<style>
    /* On enlève les marges par défaut du container parent pour cette page */
    .main-wrapper {
        margin-top: -1.5rem;
    }

    .hero-section {
        position: relative;
        width: 100vw;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        min-height: 90vh;
        display: flex;
        align-items: center;
        /* Image de muscu pro en fond */
        background: linear-gradient(rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0.75)), 
                    url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=2070&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        background-attachment: fixed; /* Effet parallaxe sympa */
        color: white;
    }

    .glitch-title {
        font-family: 'Bebas Neue', cursive;
        font-size: calc(3.5rem + 5vw);
        line-height: 0.8;
        letter-spacing: -2px;
        text-shadow: 3px 3px 0px #ff4d4d;
    }

    .outline-text {
        color: transparent;
        -webkit-text-stroke: 2px #ff4d4d;
        text-shadow: none;
    }

    .btn-gym {
        border-radius: 0;
        padding: 1.2rem 2.5rem;
        font-family: 'Bebas Neue', cursive;
        font-size: 1.5rem;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

    .btn-gym:hover {
        transform: scale(1.05);
        box-shadow: 0 0 20px rgba(255, 77, 77, 0.5);
    }

    .stat-bar {
        background: rgba(0, 0, 0, 0.6);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        padding: 2rem 0;
    }
</style>

<div class="main-wrapper">
    {# SECTION HERO PLEINE LARGEUR #}
    <section class="hero-section">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-12">
                    <h1 class="glitch-title text-uppercase mb-4">
                        DÉPASSEZ VOS <br><span class="outline-text">LIMITES</span>
                    </h1>
                    
                    <p class="lead mb-5 mx-auto" style="max-width: 700px; font-size: 1.4rem; font-weight: 300;">
                        L'outil de tracking <strong class="text-danger">BRUT</strong> pour ceux qui transforment la fonte en résultats. 
                        Pas de blabla, juste de la performance.
                    </p>
                    
                    <div class="d-grid gap-3 d-sm-flex justify-content-sm-center mb-5">
                        <a href="{{ path('app_register') }}" class="btn btn-danger btn-gym shadow-lg">
                            REJOINDRE L'ÉLITE
                        </a>
                        <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-gym">
                            CONNEXION ATHLÈTE
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# BANDEAU DE STATS #}
    <div class="stat-bar w-100" style="position: relative; width: 100vw; left: 50%; right: 50%; margin-left: -50vw; margin-right: -50vw;">
        <div class="container text-center text-uppercase fw-bold">
            <div class="row">
                <div class="col-6 col-md-3 border-end border-secondary">
                    <span class="d-block h2 mb-0">100%</span>
                    <small class="text-danger">Gratuit</small>
                </div>
                <div class="col-6 col-md-3 border-end border-secondary">
                    <span class="d-block h2 mb-0">BRUT</span>
                    <small class="text-danger">SANS PUB</small>
                </div>
                <div class="col-6 col-md-3 border-end border-secondary">
                    <span class="d-block h2 mb-0">PR</span>
                    <small class="text-danger">TRACKER</small>
                </div>
                <div class="col-6 col-md-3">
                    <span class="d-block h2 mb-0">80+</span>
                    <small class="text-danger">EXERCICES</small>
                </div>
            </div>
        </div>
    </div>
</div>

{# SECTION BLANCHE SIMPLE POUR LE CONTENU #}
<section class="py-5 bg-white text-dark">
    <div class="container">
        <div class="row text-center g-5 py-5">
            <div class="col-md-4">
                <i class="bi bi-graph-up-arrow display-4 text-danger"></i>
                <h3 class="fw-bold mt-3">ANALYSEZ</h3>
                <p>Progression visuelle de votre tonnage total.</p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-journal-check display-4 text-danger"></i>
                <h3 class="fw-bold mt-3">ORGANISEZ</h3>
                <p>Historique complet de vos entraînements.</p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-fire display-4 text-danger"></i>
                <h3 class="fw-bold mt-3">EXPLOSEZ</h3>
                <p>Suivez et battez vos records personnels.</p>
            </div>
        </div>
    </div>
</section>
{% endblock %}