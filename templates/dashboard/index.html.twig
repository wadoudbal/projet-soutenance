{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord - PERFORMANCE ID{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
<style>
    :root {
        --sidebar-width: 280px;
        --primary-red: #ff3131;
    }

    .dashboard-container {
        display: flex;
        min-height: 100vh;
        background: transparent;
    }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width); 
        width: calc(100% - var(--sidebar-width));
        padding: 3rem;
        transition: all 0.3s ease;
    }

    .glass-card {
        background: rgba(0, 0, 0, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        padding: 2rem;
        height: 100%;
        transition: transform 0.3s ease;
    }
    
    .glass-card:hover { border-color: rgba(255, 49, 49, 0.3); }

    .border-success-glow {
        border: 2px solid #198754 !important;
        box-shadow: 0 0 15px rgba(25, 135, 84, 0.2);
    }

    .btn-delete-goal {
        color: rgba(255, 255, 255, 0.3);
        transition: all 0.2s;
        background: none;
        border: none;
        padding: 5px;
    }

    .btn-delete-goal:hover {
        color: var(--primary-red);
        transform: scale(1.2);
    }

    .font-bebas { font-family: 'Bebas Neue', sans-serif; }

    .progress {
        height: 8px;
        background: rgba(255,255,255,0.1);
        border-radius: 10px;
        overflow: hidden;
    }

    @media (max-width: 992px) {
        :root { --sidebar-width: 80px; }
        .main-content { margin-left: var(--sidebar-width); width: calc(100% - var(--sidebar-width)); padding: 1.5rem; }
    }

    @media (max-width: 576px) {
        .main-content { margin-left: 0 !important; width: 100% !important; padding: 1.5rem 1rem 100px 1rem !important; }
        header.row { text-align: center; }
        header.row h1 { font-size: 1.8rem !important; }
        .w-100-mobile { width: 100% !important; }
    }
</style>

<div class="dashboard-container">
    {{ include('_sidebar.html.twig') }}

    <main class="main-content">
        <header class="row mb-5 align-items-center">
            <div class="col-md-8">
                <h1 class="display-5 fw-bold text-white">SALUT, {{ app.user.firstName|default('Athlète')|upper }}</h1>
                <p class="text-danger fw-bold text-uppercase" style="letter-spacing: 2px;">Prêt pour ta prochaine séance ?</p>
            </div>
            <div class="col-md-4 text-md-end">
                <a href="{{ path('app_workout_new') }}" class="btn btn-danger btn-lg fw-bold rounded-0 shadow-lg px-4 w-100-mobile">
                    <i class="bi bi-plus-circle me-2"></i>SÉANCE
                </a>
            </div>
        </header>

        <section aria-labelledby="current-goal-title">
            {% if goal %}
            <div class="row mb-5">
                <div class="col-12">
                    <div class="glass-card position-relative {{ pourcentage >= 100 ? 'border-success-glow' : '' }}" style="border-left: 4px solid var(--primary-red);">
                        
                        {# --- BOUTON SUPPRIMER --- #}
                        <div class="position-absolute top-0 end-0 m-3" style="z-index: 5;">
                            <form method="post" action="{{ path('app_goal_delete', {'id': goal.id}) }}" onsubmit="return confirm('Supprimer cet objectif ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ goal.id) }}">
                                <button type="submit" class="btn-delete-goal" title="Supprimer l'objectif">
                                    <i class="bi bi-trash3 fs-5"></i>
                                </button>
                            </form>
                        </div>

                        {% if pourcentage >= 100 %}
                            <div class="text-center py-5">
                                <i class="bi bi-patch-check-fill text-success mb-3" style="font-size: 3rem;"></i>
                                <h2 class="text-white font-bebas m-0" style="font-size: 2.5rem;">OBJECTIF ATTEINT !</h2>
                                <p class="text-white-50 mb-4"><strong>{{ goal.targetWeight }} KG</strong> sur <strong>{{ goal.exercise.name|default('Exercice') }}</strong>.</p>
                                <a href="{{ path('app_goal_new') }}" class="btn btn-success fw-bold rounded-0 px-5">NOUVEL OBJECTIF</a>
                            </div>
                        {% else %}
                            <div class="d-flex justify-content-between align-items-end mb-3 pe-4">
                                <div>
                                    <h2 id="current-goal-title" class="text-white-50 small text-uppercase mb-1" style="font-size: 0.75rem;">Objectif : {{ goal.exercise.name|default('Exercice') }}</h2>
                                    <p class="text-white m-0 font-bebas" style="font-size: 2rem;">{{ goal.targetWeight }} KG</p>
                                </div>
                                <div class="text-danger fw-bold fs-4">{{ pourcentage|round }}%</div>
                            </div>
                            <div class="progress">
                                <div class="progress-bar bg-danger" 
                                     id="js-progress-bar" 
                                     role="progressbar" 
                                     style="width: 0%;" 
                                     data-pourcentage="{{ pourcentage|default(0) }}"
                                     aria-valuenow="{{ pourcentage }}" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100"></div>
                            </div>
                            <div class="d-flex justify-content-between mt-3 small">
                                <span class="text-white-50">Actuel : <strong class="text-white">{{ recordAbsolu|default(0) }} kg</strong></span>
                                <span class="text-white-50">Cible : <strong class="text-white">{{ goal.targetWeight }} kg</strong></span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% else %}
            <div class="row mb-5">
                <div class="col-12 text-center">
                    <a href="{{ path('app_goal_new') }}" class="glass-card d-block text-decoration-none py-4">
                        <p class="text-white m-0 font-bebas" style="letter-spacing: 2px;">+ DÉFINIR UN OBJECTIF</p>
                    </a>
                </div>
            </div>
            {% endif %}
        </section>

        <section class="row g-4 mb-5">
            <div class="col-md-4">
                <article class="glass-card text-center">
                    <h2 class="text-white-50 small text-uppercase fw-bold mb-2">Volume Total</h2>
                    <div class="h1 m-0 text-white font-bebas" style="font-size: 2.5rem;">
                        {{ volumeTotal|default(0)|number_format(0, ',', ' ') }} <span class="fs-6 text-danger">KG</span>
                    </div>
                </article>
            </div>
            <div class="col-md-4">
                <article class="glass-card text-center">
                    <h2 class="text-white-50 small text-uppercase fw-bold mb-2">Séances / Sem</h2>
                    <div class="h1 m-0 text-white font-bebas" style="font-size: 2.5rem;">
                        {{ seancesSemaine|default(0) }} <span class="fs-6 text-danger">FOIS</span>
                    </div>
                </article>
            </div>
            <div class="col-md-4">
                <article class="glass-card text-center">
                    <h2 class="text-white-50 small text-uppercase fw-bold mb-2">Record Absolu</h2>
                    <div class="h1 m-0 text-white font-bebas" style="font-size: 2.5rem;">
                        {{ recordAbsolu|default(0) }} <span class="fs-6 text-danger">KG</span>
                    </div>
                </article>
            </div>
        </section>
    </main>
</div>
{% endblock %}

{% block javascripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const bar = document.getElementById('js-progress-bar');
        if(bar) {
            const p = parseFloat(bar.dataset.pourcentage) || 0;
            setTimeout(() => {
                bar.style.transition = "width 1.5s cubic-bezier(0.1, 0.5, 0.5, 1)";
                bar.style.width = Math.min(p, 100) + "%";
                if(p >= 100) {
                    bar.classList.remove('bg-danger');
                    bar.classList.add('bg-success');
                }
            }, 100);
        }
    });
</script>
{% endblock %}