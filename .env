APP_ENV=prod
APP_DEBUG=0

# 1. MySQL : On utilise le nom du service "database" défini dans le docker-compose
DATABASE_URL="mysql://root:root@database:3306/perfid?serverVersion=8.0&charset=utf8mb4"

# 2. MongoDB : On utilise le nom du service "mongodb"
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=perfid_logs

# 3. URI par défaut : On passe sur le port 80 (donc plus besoin de préciser :8080)
DEFAULT_URI=http://localhost