{% extends 'base.html.twig' %}

{# --- SUPPRESSION DE LA NAVBAR --- #}
{% block navbar %}{% endblock %}

{% block title %}Connexion | Performance ID{% endblock %}

{% block body %}
<style>
    :root { --primary: #ff3131; --bg-dark: #0f0f0f; }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #050505; /* Plus rapide que transparent */
    }

    .auth-card {
        width: 100%;
        max-width: 420px;
        margin: 1.5rem;
        padding: 2.5rem;
        background: var(--bg-dark); 
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-top: 4px solid var(--primary);
        box-shadow: 0 15px 35px rgba(0,0,0,0.9);
        border-radius: 4px;
        animation: fadeIn 0.3s ease-out;
    }

    .auth-h1 {
        font-family: 'Bebas Neue', Impact, sans-serif;
        font-size: 3rem;
        color: #fff;
        text-align: center;
        margin: 0;
        letter-spacing: 2px;
    }

    .auth-sub {
        display: block;
        text-align: center;
        color: var(--primary);
        font-weight: 800;
        margin-bottom: 2rem;
        font-size: 0.75rem;
        letter-spacing: 4px;
    }

    .form-group { margin-bottom: 1.2rem; }

    .form-label {
        display: block;
        color: rgba(255,255,255,0.7);
        font-weight: 700;
        margin-bottom: 0.4rem;
        font-size: 0.75rem;
        text-transform: uppercase;
    }

    .password-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .form-input {
        width: 100%;
        padding: 0.85rem;
        background: #1a1a1a !important; /* Visibilité immédiate */
        border: 1px solid #333;
        color: #fff !important;
        border-radius: 0;
        transition: border-color 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: var(--primary);
        background: #222 !important;
    }

    .toggle-password {
        position: absolute;
        right: 12px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: flex;
        color: #666;
    }

    .btn-submit {
        width: 100%;
        padding: 1.1rem;
        background: var(--primary);
        color: #fff;
        border: none;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.4rem;
        letter-spacing: 1px;
        cursor: pointer;
        margin-top: 0.5rem;
        transition: filter 0.2s;
    }

    .btn-submit:hover { filter: brightness(1.1); }

    .error-box {
        background: rgba(255, 49, 49, 0.1);
        color: #ff3131;
        padding: 0.8rem;
        border: 1px solid var(--primary);
        margin-bottom: 1.5rem;
        text-align: center;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .auth-footer {
        margin-top: 1.5rem;
        text-align: center;
        color: #777;
        font-size: 0.85rem;
    }

    .auth-footer a {
        color: #fff;
        font-weight: 800;
        text-decoration: none;
        border-bottom: 1px solid var(--primary);
    }

    .back-home {
        display: inline-block;
        margin-top: 1rem;
        font-size: 0.7rem;
        color: #555 !important;
        text-decoration: none !important;
        text-transform: uppercase;
        border: none !important;
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>

<main class="auth-wrapper">
    <article class="auth-card">
        <header>
            <h1 class="auth-h1">PERFORMANCE <span style="color:var(--primary)">ID</span></h1>
            <span class="auth-sub">ACCÈS ATHLÈTE</span>
        </header>

        <form method="post">
            {% if error %}
                <div class="error-box">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input type="email" value="{{ last_username }}" name="email" id="email" class="form-input" required autofocus placeholder="athlete@email.com">
            </div>

            <div class="form-group">
                <label for="password" class="form-label">Mot de passe</label>
                <div class="password-container">
                    <input type="password" name="password" id="password" class="form-input" required style="padding-right: 45px;" placeholder="••••••••">
                    <button type="button" id="toggleBtn" class="toggle-password">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn-submit">SE CONNECTER</button>
        </form>

        <footer class="auth-footer">
            <p>Pas encore membre ? <a href="{{ path('app_register') }}">S'INSCRIRE</a></p>
            <a href="{{ path('app_home') }}" class="back-home">← Retour à l'accueil</a>
        </footer>
    </article>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const btn = document.getElementById('toggleBtn');
        const input = document.getElementById('password');
        const icon = document.getElementById('eyeIcon');

        if(btn && input) {
            btn.addEventListener('click', function() {
                const isPass = input.type === 'password';
                input.type = isPass ? 'text' : 'password';
                icon.className = isPass ? 'bi bi-eye-slash' : 'bi bi-eye';
                icon.style.color = isPass ? '#ff3131' : '#666';
            });
        }
    });
</script>
{% endblock %}