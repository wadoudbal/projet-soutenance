{% extends 'base.html.twig' %}

{% block title %}Performance ID - Dashboard{% endblock %}

{% block body %}
<style>
    /* ON SUPPRIME LE BLOC :host, body { ... } QUI ÉTAIT ICI */
    /* Cela permet à l'image de base.html.twig de s'afficher enfin partout */

    .welcome-header {
        border-left: 5px solid #dc3545;
        padding-left: 25px;
        margin-bottom: 50px;
    }

    .card-stat {
        background: rgba(0, 0, 0, 0.65) !important; 
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 30px;
        text-align: center;
        transition: 0.4s;
    }
    
    .card-stat:hover {
        background: rgba(220, 53, 69, 0.1) !important;
        border-color: #dc3545;
        transform: translateY(-5px);
    }

    .stat-title {
        color: #aaa;
        font-size: 0.8rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .stat-number {
        font-family: 'Bebas Neue';
        font-size: 3.5rem;
        line-height: 1;
    }

    .graph-box {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 25px;
        height: 300px;
    }

    .bar-item {
        background: #dc3545;
        width: 45px;
        position: relative;
        height: var(--bar-height);
        transition: 0.8s cubic-bezier(0.2, 1, 0.3, 1);
    }

    .bar-item:hover { 
        background: #ff1e32; 
        box-shadow: 0 0 20px rgba(220, 53, 69, 0.6); 
    }

    .bar-val {
        position: absolute;
        top: -30px;
        left: 50%;
        transform: translateX(-50%);
        font-family: 'Bebas Neue';
        font-size: 1.1rem;
    }
</style>

<div class="container py-4">
    {# HEADER BIENVENUE #}
    <div class="row align-items-center mb-5">
        <div class="col-md-8 welcome-header">
            <h4 class="text-danger mb-0 text-uppercase" style="letter-spacing: 3px;">Athlete Dashboard</h4>
            <h1 class="display-3 fw-bold m-0 text-white">
                BIENVENUE, {{ app.user.userIdentifier|split('@')[0]|upper }}
            </h1>
        </div>
        <div class="col-md-4 text-md-end">
            {# CHANGEMENT : SÉANCE AU LIEU DE SÉRIE #}
            <a href="{{ path('app_workout_new') }}" class="btn btn-danger btn-lg px-5 py-3 fs-4 shadow-lg border-0 rounded-0">
                <i class="bi bi-plus-lg me-2"></i>NOUVELLE SÉANCE
            </a>
        </div>
    </div>

    {# STATS BLOCKS #}
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card-stat">
                <div class="stat-title">Volume Total</div>
                <div class="stat-number text-danger">{{ totalVolume|number_format(0, ',', ' ') }}</div>
                <div class="small text-white-50">KILOGRAMMES</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-stat">
                <div class="stat-title">Séances</div>
                <div class="stat-number text-white">{{ workoutCount }}</div>
                <div class="small text-white-50">COMPLÉTÉES</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-stat">
                <div class="stat-title">Séries</div>
                <div class="stat-number text-white">{{ allWorkouts|length }}</div>
                <div class="small text-white-50">TOTALES</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-stat">
                <div class="stat-title">Dernière Charge</div>
                <div class="stat-number text-warning">{{ lastWorkouts|length > 0 ? lastWorkouts[0].weight : 0 }}</div>
                <div class="small text-white-50">KG SOULEVÉS</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        {# GRAPH #}
        <div class="col-lg-8">
            <div class="card-stat text-start h-100 p-4">
                <h4 class="mb-4 text-uppercase text-white"><i class="bi bi-activity text-danger me-2"></i>Analyse d'intensité</h4>
                <div class="graph-box d-flex align-items-end justify-content-around rounded shadow-sm">
                    {% for workout in lastWorkouts|reverse %}
                        {% set pct = (workout.weight / 2) > 100 ? 100 : (workout.weight / 2) %}
                        <div class="bar-item" style="--bar-height: {{ pct }}%;" 
                             data-bs-toggle="tooltip" 
                             title="{{ workout.exercise ? workout.exercise.name : 'Exercice' }}">
                            <span class="bar-val text-white">{{ workout.weight }}</span>
                        </div>
                    {% else %}
                        <p class="text-white-50 italic">Aucune donnée disponible.</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# RECORDS #}
        <div class="col-lg-4">
            <div class="card-stat h-100 p-4 text-start">
                <h4 class="mb-4 border-bottom border-danger pb-2 text-uppercase text-white">Top Records</h4>
                {% for exercise, weight in personalRecords %}
                    <div class="d-flex justify-content-between align-items-center mb-3 bg-black bg-opacity-40 p-3 rounded border border-secondary border-opacity-25">
                        <span class="text-white-50">{{ exercise }}</span>
                        <span class="h4 m-0 text-warning">{{ weight }} KG</span>
                    </div>
                {% else %}
                    <p class="text-white-50 italic">Aucun record enregistré.</p>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        tooltipTriggerList.map(function (el) { return new bootstrap.Tooltip(el) })
    });
</script>
{% endblock %}