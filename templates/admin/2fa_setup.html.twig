{% extends '@EasyAdmin/page/content.html.twig' %}

{# --- PROTECTION ANTI-CRASH --- #}
{% if ea is not defined or ea is null %}
    {% set ea = { 'i18n': { 'translationDomain': 'messages', 'htmlLocale': 'fr', 'textDirection': 'ltr' } } %}
{% endif %}

{% block content_title %}Sécurité du compte{% endblock %}

{% block main %}
    <div class="content-panel">
        <div class="content-panel-body p-5 text-center">
            
            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            {% if isEnabled %}
                <div class="mb-4">
                    <i class="fa fa-shield-check text-success fa-4x"></i>
                    <h2 class="mt-3">Protection 2FA Active</h2>
                </div>
                <p class="text-muted">Votre accès administrateur est sécurisé.</p>
                <div class="mt-4">
                    <a href="{{ path('admin_2fa_disable') }}" 
                       class="btn btn-danger btn-lg shadow-sm" 
                       onclick="return confirm('Voulez-vous vraiment désactiver la 2FA ?')">
                        <i class="fa fa-unlock-alt mr-2"></i> Désactiver la sécurité
                    </a>
                </div>
            {% else %}
                <div class="mb-4">
                    <i class="fa fa-shield-exclamation text-warning fa-4x"></i>
                    <h2 class="mt-3">Activer la 2FA</h2>
                </div>
                <p class="text-muted small mb-4">Scannez ce code avec Google Authenticator.</p>
                
                <div class="my-4 d-inline-block p-3 bg-white border shadow-sm" style="border-radius: 10px;">
                    <img src="{{ qrCodeDataUri }}" style="width: 250px;">
                </div>

                <div class="alert alert-light border">
                    <small class="text-muted d-block">Clé manuelle :</small>
                    <code class="h4 text-dark">{{ secret }}</code>
                </div>

                <div class="mt-4">
                    <a href="{{ path('admin') }}" class="btn btn-primary shadow">J'ai scanné le code</a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}