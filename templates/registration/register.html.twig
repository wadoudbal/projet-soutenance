{% extends 'base.html.twig' %}

{# --- SUPPRESSION DE LA NAVBAR --- #}
{% block navbar %}{% endblock %}

{# --- SEO CRITIQUE --- #}
{% block meta_tags %}
    <meta name="description" content="Rejoignez Performance ID. Créez votre compte d'athlète pour suivre vos records et votre progression.">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="Créer un profil | Performance ID">
    <link rel="canonical" href="{{ app.request.uri }}">
{% endblock %}

{% block title %}Créer un profil | Performance ID{% endblock %}

{% block body %}
<style>
    :root { --primary: #ff3131; }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
    }

    .auth-card {
        width: 100%;
        max-width: 480px;
        margin: 1.5rem;
        padding: 2.5rem;
        background: rgba(15, 15, 15, 0.95); 
        border-top: 4px solid var(--primary);
        box-shadow: 0 20px 50px rgba(0,0,0,0.8);
        backdrop-filter: blur(12px);
        border-radius: 8px;
        animation: fadeIn 0.4s ease-out;
    }

    .auth-h1 {
        font-family: 'Bebas Neue', Impact, sans-serif;
        font-size: 2.8rem;
        color: #fff;
        text-align: center;
        margin: 0;
    }

    .auth-sub {
        display: block;
        text-align: center;
        color: var(--primary);
        font-weight: 800;
        margin-bottom: 2rem;
        font-size: 0.75rem;
    }

    .form-label {
        color: #ffffff; 
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        display: block;
    }

    /* CORRECTION : On force l'affichage du texte */
    .form-input {
        width: 100%;
        padding: 0.85rem;
        background: rgba(255, 255, 255, 0.08) !important;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #ffffff !important; /* Texte bien blanc */
        border-radius: 4px;
        transition: all 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: var(--primary);
        background: rgba(255, 255, 255, 0.15) !important;
    }

    /* Pour le champ mot de passe avec l'oeil */
    .password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .toggle-password {
        position: absolute;
        right: 12px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: flex;
    }

    .btn-submit {
        width: 100%;
        padding: 1rem;
        background: var(--primary);
        color: #fff;
        border: none;
        font-weight: 800;
        text-transform: uppercase;
        margin-top: 1.5rem;
        cursor: pointer;
        border-radius: 4px;
    }

    .auth-footer { margin-top: 1.5rem; text-align: center; color: #ddd; font-size: 0.9rem; }
    .auth-footer a { color: #fff; font-weight: 800; text-decoration: underline; }

    /* Custom Checkbox corrigé */
    .checkbox-container {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #eee;
        font-size: 0.85rem;
        margin-top: 1rem;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<main class="auth-wrapper">
    <article class="auth-card">
        <header>
            <h1 class="auth-h1">PERFORMANCE <span style="color:var(--primary)">ID</span></h1>
            <span class="auth-sub">REJOINDRE L'ÉLITE</span>
        </header>

        {{ form_start(registrationForm) }}
            <div class="row g-3">
                <div class="col-6">
                    <label class="form-label">Prénom</label>
                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-input', 'placeholder': 'Prénom'}}) }}
                </div>
                <div class="col-6">
                    <label class="form-label">Nom</label>
                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-input', 'placeholder': 'Nom'}}) }}
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label">Email</label>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-input', 'placeholder': 'athlete@email.com'}}) }}
            </div>

            <div class="mt-3">
                <label class="form-label">Mot de passe</label>
                <div class="password-wrapper">
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-input', 'placeholder': '••••••••', 'id': 'reg_pass'}}) }}
                    <button type="button" id="toggleRegPassword" class="toggle-password">
                        <svg id="eyeIcon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="checkbox-container">
                {{ form_widget(registrationForm.agreeTerms) }}
                <label for="{{ registrationForm.agreeTerms.vars.id }}">J'accepte les conditions d'utilisation.</label>
            </div>

            <button type="submit" class="btn-submit">Créer mon compte</button>
        {{ form_end(registrationForm) }}

        <footer class="auth-footer">
            <p>Déjà inscrit ? <a href="{{ path('app_login') }}">SE CONNECTER</a></p>
            <a href="{{ path('app_home') }}" style="font-size: 0.75rem; color: #bbb; margin-top: 1rem; display: inline-block;">← Retour à l'accueil</a>
        </footer>
    </article>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Logique de l'oeil pour le mot de passe
        const btn = document.getElementById('toggleRegPassword');
        // On récupère l'ID généré par Symfony pour le plainPassword
        const input = document.getElementById('{{ registrationForm.plainPassword.vars.id }}');
        const icon = document.getElementById('eyeIcon');

        if(btn && input) {
            btn.addEventListener('click', function() {
                const isPass = input.type === 'password';
                input.type = isPass ? 'text' : 'password';
                icon.style.stroke = isPass ? '#ff3131' : 'rgba(255,255,255,0.5)';
            });
        }
    });
</script>
{% endblock %}