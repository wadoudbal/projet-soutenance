{% extends 'base.html.twig' %}

{% block title %}Performance ID - Modifier la séance{% endblock %}

{% block body %}
<style>
    .bebas { font-family: 'Bebas Neue', cursive; letter-spacing: 1px; }

    /* Conteneur central style "Glassmorphism" sombre */
    .edit-container {
        background: rgba(15, 15, 15, 0.9);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-top: 4px solid #dc3545;
        padding: 40px;
        margin-top: 50px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.5);
    }

    /* Style du formulaire (pour impacter _form.html.twig) */
    label {
        color: #bbbbbb;
        text-transform: uppercase;
        font-family: 'Bebas Neue';
        font-size: 1.1rem;
        margin-bottom: 5px;
    }

    .form-control {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        color: white !important;
        padding: 12px !important;
        margin-bottom: 20px !important;
    }

    .form-control:focus {
        border-color: #dc3545 !important;
        box-shadow: 0 0 10px rgba(220, 53, 69, 0.3) !important;
    }

    .btn-update {
        background: #dc3545;
        border: none;
        font-family: 'Bebas Neue';
        font-size: 1.5rem;
        padding: 10px;
        transition: 0.3s;
    }

    .btn-update:hover {
        background: #a71d2a;
        transform: translateY(-2px);
    }

    .back-link {
        color: #aaa;
        text-decoration: none;
        transition: 0.3s;
        font-family: 'Bebas Neue';
    }

    .back-link:hover {
        color: #fff;
    }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="edit-container">
                
                {# EN-TÊTE #}
                <div class="text-center mb-4">
                    <h1 class="bebas display-4 text-white m-0">MODIFIER LA <span class="text-danger">SÉANCE</span></h1>
                    <p class="text-white-50 small">Ajuste tes performances pour garder un journal précis</p>
                </div>

                <hr class="border-secondary mb-4">

                {# LE FORMULAIRE #}
                <div class="mb-4">
                    {# On passe 'Enregistrer' au lieu de 'Update' #}
                    {{ include('workout/_form.html.twig', {'button_label': 'METTRE À JOUR'}) }}
                </div>

                {# ACTIONS SUPPLÉMENTAIRES #}
                <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top border-secondary border-opacity-25">
                    <a href="{{ path('app_workout_index') }}" class="back-link">
                        <i class="bi bi-arrow-left me-2"></i>RETOUR À L'HISTORIQUE
                    </a>
                    
                    {# Le bouton supprimer est souvent déjà inclus dans _delete_form.html.twig #}
                    {{ include('workout/_delete_form.html.twig') }}
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}