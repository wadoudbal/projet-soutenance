{% extends 'base.html.twig' %}

{% block title %}Mon Profil Santé - Performance ID{% endblock %}

{% block body %}
<style>
    :root {
        --sidebar-width: 280px;
    }

    .dashboard-container {
        display: flex;
        min-height: 100vh;
    }

    /* --- STRUCTURE PRINCIPALE --- */
    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        width: calc(100% - var(--sidebar-width));
        padding: 3rem;
        transition: all 0.3s ease;
    }

    .bebas { font-family: 'Bebas Neue', cursive; letter-spacing: 1px; }
    
    .card-dark { 
        background: rgba(0, 0, 0, 0.7); 
        border: 1px solid rgba(255,255,255,0.1); 
        border-top: 4px solid var(--primary-red); 
        color: white; 
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        /* height: 100%;  <-- Supprimé pour laisser les cartes s'adapter au contenu */
    }
    
    .stat-box { 
        background: rgba(255, 255, 255, 0.05); 
        padding: 12px; 
        border-left: 3px solid var(--primary-red); 
    }

    .imc-badge { 
        font-family: 'Bebas Neue'; 
        font-size: 1.8rem; 
        padding: 5px 20px; 
    }
    
    .imc-success { background-color: var(--success-green); color: #fff; }
    .imc-warning { background-color: var(--warning-orange); color: #000; }
    .status-success { color: var(--success-green); }
    .status-warning { color: var(--warning-orange); }

    .form-control {
        border-radius: 0;
        transition: all 0.2s;
    }

    .form-control:focus {
        background-color: #1a1a1a !important;
        color: white;
        border-color: var(--primary-red);
        box-shadow: none;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 992px) {
        :root { --sidebar-width: 80px; }
        .main-content { 
            margin-left: var(--sidebar-width); 
            width: calc(100% - var(--sidebar-width));
            padding: 2rem 1.5rem; 
        }
    }

    @media (max-width: 576px) {
        .main-content { 
            margin-left: 0 !important; 
            width: 100% !important;
            padding: 1.5rem 1rem 100px 1rem !important; 
        }
        .display-3 { font-size: 2.5rem !important; }
    }
</style>

<div class="dashboard-container">
    {{ include('_sidebar.html.twig') }}

    <main class="main-content">
        <header class="mb-5">
            <h4 class="text-danger mb-0 bebas" style="letter-spacing: 3px;">PARAMÈTRES DU COMPTE</h4>
            <h1 class="bebas display-3 m-0 text-white">PROFIL <span class="text-danger">SANTÉ</span></h1>
        </header>

        <div class="row g-4">
            {# COLONNE GAUCHE : INFOS & SANTÉ (Reste large) #}
            <div class="col-lg-7">
                <div class="card card-dark p-4 shadow-lg" style="height: auto;">
                    <h2 class="bebas mb-4"><i class="bi bi-heart-pulse text-danger me-2"></i>Ma Condition <span class="text-danger">Physique</span></h2>
                    
                    {{ form_start(form) }}
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="bebas text-white-50 small">Prénom / Pseudo</label>
                            {{ form_widget(form.pseudo, {'attr': {'class': 'form-control bg-dark text-white border-secondary'}}) }}
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <label class="bebas text-white-50 small">Poids (kg)</label>
                            {{ form_widget(form.poids, {'attr': {'class': 'form-control bg-dark text-white border-secondary'}}) }}
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <label class="bebas text-white-50 small">Taille (cm)</label>
                            {{ form_widget(form.taille, {'attr': {'class': 'form-control bg-dark text-white border-secondary'}}) }}
                        </div>
                    </div>
                    <button type="submit" class="btn btn-danger bebas w-100 mt-2 py-2 fs-5">Mettre à jour</button>
                    {{ form_end(form) }}

                    {% if app.user.poids and app.user.taille %}
                        {% set imc = app.user.poids / ((app.user.taille / 100) * (app.user.taille / 100)) %}
                        {% set is_healthy = imc >= 18.5 and imc <= 25 %}
                        
                        <div class="mt-4 p-3 border border-secondary border-opacity-25 bg-black bg-opacity-25">
                            <h4 class="bebas mb-2 small text-white-50 text-uppercase" style="font-size: 0.8rem;">Ton Indice de Masse Corporelle (IMC)</h4>
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                                <span class="imc-badge rounded-0 {{ is_healthy ? 'imc-success' : 'imc-warning' }}">
                                    {{ imc|number_format(1) }}
                                </span>
                                <div class="text-end">
                                    <p class="mb-0 fw-bold text-uppercase small {{ is_healthy ? 'status-success' : 'status-warning' }}">
                                        {% if imc < 18.5 %}Poids insuffisant
                                        {% elseif imc <= 25 %}Poids idéal
                                        {% elseif imc < 30 %}Surpoids
                                        {% else %}Obésité{% endif %}
                                    </p>
                                    <small class="text-white-50" style="font-size: 0.7rem;">Analyse automatique</small>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# COLONNE DROITE : SÉCURITÉ & ACTIONS (Plus courtes) #}
            <div class="col-lg-5">
                {# BLOC 2FA #}
                <div class="card card-dark p-3 shadow-lg mb-3" style="border-top-color: var(--warning-orange);">
                    <h2 class="bebas mb-3" style="font-size: 1.5rem;"><i class="bi bi-shield-lock text-warning me-2"></i>Sécurité <span class="text-warning">2FA</span></h2>
                    
                    {% if app.user.googleAuthenticatorSecret %}
                        <div class="stat-box d-flex align-items-center justify-content-between py-2" style="border-left-color: var(--success-green);">
                            <div>
                                <div class="fw-bold text-uppercase text-white-50" style="font-size: 0.7rem;">Statut</div>
                                <div class="text-success fw-bold bebas fs-5">ACTIVÉ</div>
                            </div>
                            <a href="{{ path('app_2fa_disable') }}" class="btn btn-outline-danger btn-sm bebas" onclick="return confirm('Désactiver la sécurité ?')">Désactiver</a>
                        </div>
                    {% else %}
                        <div class="stat-box d-flex align-items-center justify-content-between py-2" style="border-left-color: var(--primary-red);">
                            <div>
                                <div class="fw-bold text-uppercase text-white-50" style="font-size: 0.7rem;">Statut</div>
                                <div class="text-danger fw-bold bebas fs-5">DÉSACTIVÉ</div>
                            </div>
                            <a href="{{ path('app_2fa_enable') }}" class="btn btn-warning btn-sm text-dark fw-bold bebas">ACTIVER</a>
                        </div>
                    {% endif %}
                </div>

                {# ACTIONS COMPTE #}
                <div class="card card-dark p-3 shadow-lg">
                    <h2 class="bebas mb-3" style="font-size: 1.5rem;"><i class="bi bi-person-gear me-2"></i>Mon <span class="text-danger">Compte</span></h2>
                    
                    <div class="d-grid gap-2">
                        <a href="{{ path('app_change_password') }}" class="btn btn-outline-light btn-sm bebas py-2">
                            <i class="bi bi-key me-2"></i>Changer le mot de passe
                        </a>

                        <form method="post" action="{{ path('app_user_delete') }}" onsubmit="return confirm('Confirmez-vous la suppression définitive ?');" class="text-center">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                            <button type="submit" class="btn btn-link text-danger btn-sm text-decoration-none p-0 mt-1 opacity-75">
                                <i class="bi bi-trash3 me-1"></i> Supprimer mon compte
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}